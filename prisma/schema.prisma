generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  favorites     Favorite[]
  sessions      Session[]
  userXI        UserXI?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Favorite {
  id        String       @id @default(cuid())
  name      String
  logo      String?
  userId    String
  createdAt DateTime     @default(now())
  itemId    Int
  type      FavoriteType
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, itemId])
  @@map("FavoriteLeague")
}

enum FavoriteType {
  LEAGUE
  TEAM
  MATCH
  PLAYER
}

model UserXI {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  formation String   @default("4-3-3")
  players   Json // array of 11 player objects or nulls
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlayerIndex {
  id          Int      @id
  name        String
  photo       String?
  nationality String?
  position    String?
  teamId      Int?
  teamName    String?
  teamLogo    String?
  leagueId    Int?
  season      Int
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([teamId])
}